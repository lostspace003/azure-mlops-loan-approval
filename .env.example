# Azure ML Workspace
SUBSCRIPTION_ID=<your-subscription-id>
RESOURCE_GROUP=rg-mlops-loan-approval
WORKSPACE_NAME=mlw-loan-approval

# Azure SQL Database
SQL_SERVER=<your-sql-server>.database.windows.net
SQL_DATABASE=sqldb-loan-data
SQL_USERNAME=sqladmin
SQL_PASSWORD=<your-sql-password>

# Azure DevOps (for retrain trigger)
AZURE_DEVOPS_ORG=<your-org>
AZURE_DEVOPS_PROJECT=mlops-loan-approval
AZURE_DEVOPS_PIPELINE_ID=<ci-pipeline-id>
AZURE_DEVOPS_PAT=<your-personal-access-token>

# Monitoring
ALERT_EMAIL=<your-email@domain.com>
